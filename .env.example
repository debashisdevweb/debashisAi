# ---------------------------------------------------------------------------
# Google Generative AI (Gemini) keys. Get keys at https://aistudio.google.com/apikey
# Copy this file to `.env.local` for local dev, and set the same variables in
# your host's dashboard (e.g. Vercel → Project → Settings → Environment Variables).
# ---------------------------------------------------------------------------

# Required. Shared fallback key used by every route if a dedicated key is unset.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional. Dedicated key for the chat route (keeps chat quota separate).
# Falls back to GOOGLE_GENERATIVE_AI_API_KEY if empty.
GOOGLE_CHAT_API_KEY=

# Optional. Dedicated key(s) for Gemini text-to-speech. The TTS route rotates
# through these (plus the two above) to extend free-tier quota.
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_API_KEY_2=
